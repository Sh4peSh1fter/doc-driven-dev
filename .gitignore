/tmp-fixtures/
/sample-repos/

# Dogfood artifacts generated by the plugin in this repo.
# docs-tools/ is a copy of scripts/lib (regenerable); ignore it.
# docs-site/ source IS tracked (so GitHub Pages can build it); only its
# build output and deps are ignored (covered by build/, .docusaurus/, node_modules/ above).
/docs-tools/
